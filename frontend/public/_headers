# ponytail: Cloudflare Pages 缓存策略
# Lighthouse 报告 /assets/* 缓存只有 4 小时，导致重访时仍重新下载所有 JS/CSS。
# Vite 打包的 /assets/* 文件名带 hash，内容不变则 hash 不变，可安全长缓存。

# 带 hash 的构建产物：1 年 immutable 缓存
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# WebP 图片：1 年缓存（文件名固定但变更频率低，靠手动改名更新）
/*.webp
  Cache-Control: public, max-age=31536000, immutable

# favicon PNG：1 天缓存（小文件，便于变更）
/gualingo.png
  Cache-Control: public, max-age=86400

# 爬虫配置文件：1 小时
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600

# HTML 入口：不缓存，确保新部署立即生效
/
  Cache-Control: no-cache, no-store, must-revalidate
